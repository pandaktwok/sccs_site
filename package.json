{
  "name": "sccs-backend",
  "version": "1.0.0",
  "description": "Backend API for SCCS",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm install && npm run build",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-handler": "^1.2.0",
    "express-fileupload": "^1.5.2",
    "fs-extra": "^11.3.4",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "rss-parser": "^3.13.0",
    "webdav": "^5.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
